# Copy to server/.env and fill in. Do NOT commit .env.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Bearer token that the frontend sends as X-API-Key.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-to-a-long-random-string

# ── Network ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated. In prod, pin to your exact frontend origin(s). Example:
# CORS_ORIGINS=https://pitchlogic.app,https://www.pitchlogic.app
CORS_ORIGINS=*

# ── Storage layout (defaults to /workspace on RunPod) ────────────────────────
# WORKSPACE_DIR=/workspace
SESSION_TTL_HOURS=48
CLEANUP_INTERVAL_MINUTES=30

# ── Worker pool ──────────────────────────────────────────────────────────────
GPU_WORKERS=1
IO_WORKERS=4
TASK_TIMEOUT_SECONDS=3600

# ── Model weights (HuggingFace Hub) ──────────────────────────────────────────
HF_REPO_ID=hansdu/ai-football-assistant-weights
HF_YOLO_FILENAME=soccana_best.pt
HF_KEYPOINT_FILENAME=soccana_kpts_best.pt
# HF_TOKEN=hf_xxx  # only needed if the repo is private

# ── Optional SAMURAI tracking (leave unset to disable) ───────────────────────
# SAMURAI_SCRIPT=/workspace/samurai/run_samurai.py

# ── DashScope (Qwen-VL) — needed for AI summary feature ─────────────────────
# DASHSCOPE_API_KEY=sk-xxx
# DASHSCOPE_MODEL=qwen-vl-max-latest

LOG_LEVEL=INFO
