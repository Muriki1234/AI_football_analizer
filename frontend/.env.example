# Frontend runtime config.
# Copy to `.env.local` (gitignored) and fill in the real values before `npm run dev`.

# Base URL of the FastAPI backend (RunPod Pod HTTPS URL, or local :8000 for dev).
# When blank, the app falls back to same-origin requests via the Vite dev proxy.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Must match the API_KEY env var on the backend. Leave empty for local dev
# when the server runs without auth.
VITE_API_KEY=
